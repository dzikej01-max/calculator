<Window x:Class="CalculatorApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Простой калькулятор" 
        Height="690" 
        Width="400" 
        ResizeMode="NoResize" 
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown">

    <Grid Margin="10,10,10,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   Text="Калькулятор" 
                   FontSize="24" 
                   FontWeight="Bold" 
                   HorizontalAlignment="Center" 
                   Margin="0,0,0,20"/>

        <!-- Первое число -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Первое число:" FontSize="14" Margin="0,0,0,5"/>
            <TextBox x:Name="FirstNumberTextBox" 
                     FontSize="16" 
                     Padding="5" 
                     Height="35"/>
        </StackPanel>

        <!-- Второе число -->
        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="Второе число:" FontSize="14" Margin="0,0,0,5"/>
            <TextBox x:Name="SecondNumberTextBox" 
                     FontSize="16" 
                     Padding="5" 
                     Height="35"/>
        </StackPanel>

        <!-- Операции -->
        <StackPanel Grid.Row="3" Margin="0,0,0,15">
            <TextBlock Text="Выберите операцию:" FontSize="14" Margin="0,0,0,10"/>
            <UniformGrid Rows="2" Columns="4">
                <!-- Первая строка: + - × ÷ -->
                <Button x:Name="AddButton" 
                        Content="+"  
                        FontSize="20" 
                        Margin="2" 
                        Height="50" 
                        Background="#FF81C784"
                        Click="AddButton_Click"/>
                <Button x:Name="SubtractButton" 
                        Content="-"  
                        FontSize="20" 
                        Margin="2" 
                        Height="50" 
                        Background="#FFE57373"
                        Click="SubtractButton_Click"/>
                <Button x:Name="MultiplyButton" 
                        Content="×"  
                        FontSize="20" 
                        Margin="2" 
                        Height="50" 
                        Background="#FF64B5F6"
                        Click="MultiplyButton_Click"/>
                <Button x:Name="DivideButton" 
                        Content="÷"  
                        FontSize="20" 
                        Margin="2" 
                        Height="50" 
                        Background="#FFFFB74D"
                        Click="DivideButton_Click"/>

                <!-- Вторая строка: x^y (степень), √ (корень) -->
                <Button x:Name="PowerButton" 
                        Content="xʸ"  
                        FontSize="16" 
                        Margin="2" 
                        Height="50" 
                        Background="#FFBA68C8"
                        Click="PowerButton_Click"/>
                <Button x:Name="SqrtButton" 
                        Content="√"  
                        FontSize="16" 
                        Margin="2" 
                        Height="50"
Background="#FFBA68C8"
                        Click="SqrtButton_Click"/>
                <Button Visibility="Collapsed"/>
                <Button Visibility="Collapsed"/>
            </UniformGrid>
        </StackPanel>

        <!-- Результат -->
        <StackPanel Grid.Row="4" Margin="0,0,0,10">
            <TextBlock Text="Результат:" FontSize="14" Margin="0,0,0,5"/>
            <TextBox x:Name="ResultTextBox" 
                     FontSize="18" 
                     Padding="5" 
                     Height="40" 
                     IsReadOnly="True" 
                     Background="LightYellow" 
                     FontWeight="Bold"/>
        </StackPanel>

        <!-- Кнопка очистки -->
        <Button Grid.Row="5" 
                Content="Очистить" 
                FontSize="16" 
                Height="40" 
                Margin="0,0,0,10"
                Click="ClearButton_Click"/>

        <!-- История операций -->
        <StackPanel Grid.Row="6" Margin="0,0,0,5">
            <TextBlock Text="История операций:" FontSize="14" Margin="0,5,0,5"/>
            <ListBox x:Name="HistoryListBox" 
                     Height="120" 
                     Background="#FFF5F5F5" 
                     FontSize="12"/>
        </StackPanel>
    </Grid>
</Window>

